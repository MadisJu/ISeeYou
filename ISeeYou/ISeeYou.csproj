<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
	  
    <PackageId>ISeeYou</PackageId>
    <Version>1.0.0</Version>
    <Authors>Madis-Julius Tamberg</Authors>
    <Company>MadislolInc</Company>
    <Description>Super minimalistic auditing library to use across multiple microservices</Description>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/MadisJu/ISeeYou</PackageProjectUrl>
    <RepositoryUrl>https://github.com/MadisJu/ISeeYou</RepositoryUrl>
  </PropertyGroup>

</Project>
